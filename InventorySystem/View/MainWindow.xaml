<Window x:Class="InventorySystem.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InventorySystem.View"
        xmlns:UserControls="clr-namespace:InventorySystem.View.UserControls"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl>
            <TabItem Header="Inventory" DataContext="{Binding SpreadSheetVM}">
                <UserControls:SpreadSheet/>
            </TabItem>

            <TabItem Header="Dashboard" DataContext="{Binding DashboardVM}">
                <UserControls:DashBoard/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
