<UserControl x:Class="InventorySystem.View.UserControls.MainWindow.SpreadSheetUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InventorySystem.View.UserControls.MainWindow"
             xmlns:vm="clr-namespace:InventorySystem.ViewModel.MockData"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:MockInventory, IsDesignTimeCreatable=True}">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.7*"/>
            <ColumnDefinition Width="0.3*"/>
        </Grid.ColumnDefinitions>
        
        <DataGrid x:Name="RamData" 
              Grid.Column="0" 
              ItemsSource="{Binding RamDatas}" 
              SelectedItem="{Binding SelectedItem}" 
              IsReadOnly="True"
              AutoGenerateColumns="False" 
              CanUserResizeColumns="True"
              HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Width=".2*" Header="Name" Binding="{Binding Name}"></DataGridTextColumn>
                <DataGridTextColumn Width="100" Header="Brand" Binding="{Binding Brand}"></DataGridTextColumn>
                <DataGridTextColumn Header="Memory Type" Binding="{Binding MemoryType}"></DataGridTextColumn>
                <DataGridTextColumn Header="Module" Binding="{Binding Module}"></DataGridTextColumn>
                <DataGridTextColumn Width="100" Header="Price" Binding="{Binding Price}"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="0.15*"/>
                <RowDefinition Height="0.65*"/>
                <RowDefinition Height="0.1*"/>
                <RowDefinition Height="0.1*"/>
            </Grid.RowDefinitions>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0.3*"/>
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding SearchValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="25" FontSize="14"/>
                <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}"/>
                
            </Grid>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <Viewbox>
                    <TextBlock 
                   Text="{Binding ItemName}" 
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="Black"/>
                </Viewbox>

            </ScrollViewer>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Top">
                    <ItemsControl ItemsSource="{Binding ItemDetails}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="3.5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock  
                                        Text="{Binding Label}"
                                        FontWeight="SemiBold" 
                                        VerticalAlignment="Center" 
                                        Foreground="Gray"/>

                                    <TextBlock Grid.Column="1" 
                                       Text="{Binding Value}" 
                                       FontSize="12"
                                       VerticalAlignment="Center" 
                                       TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width=".35*"/>
                </Grid.ColumnDefinitions>

                <Button Margin="5" Content="Dashboard" Command="{Binding DashboardCommand}"/>
                <Button Grid.Column="1" Margin="5" Content="Setting" Command="{Binding SettingCommand}"></Button>
            </Grid>
            
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="5" Background="#E0E0E0" Margin="5">
                    <Button Content="Insert" Background="Transparent" BorderThickness="0" Command="{Binding InsertCommand}" ToolTip="Insert data from a file"/>
                </Border>

                <Border Grid.Column="1" CornerRadius="5" Background="#E0E0E0" Margin="5">
                    <Button Content="Add" Background="Transparent" BorderThickness="0" Command="{Binding AddCommand}" ToolTip="Add a single data"/>
                </Border>

                <Border Grid.Column="2" CornerRadius="5" Background="#E0E0E0" Margin="5">
                    <Button Content="Update" Background="Transparent" BorderThickness="0" Command="{Binding UpdateCommand}" ToolTip="Update the selected data"/>
                </Border>

                <Border Grid.Column="3" CornerRadius="5" Background="Red" Margin="5">
                    <Button Content="Delete" Background="Transparent" Foreground="White" BorderThickness="0" Command="{Binding DeleteCommand}" ToolTip="Delete selected data"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
