<Window x:Class="InventorySystem.View.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InventorySystem.View"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:Model="clr-namespace:InventorySystem.Model"
        mc:Ignorable="d"
        Title="DashboardWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="65"/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Margin="25,5,25,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0.3*"/>
            </Grid.ColumnDefinitions>

            <TextBox Text="{Binding SearchValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="25" FontSize="14"/>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}" Height="25"/>
        </Grid>

        <Grid Grid.Row="1">
            <ItemsControl ItemsSource="{Binding DashboardStats}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="5"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="2.5" BorderThickness="2" Background="LightGray" CornerRadius="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="18"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Label}" 
                                   Margin="10,0,0,0" 
                                   FontWeight="Medium" 
                                   HorizontalAlignment="Left" 
                                   VerticalAlignment="Bottom"/>
                                <TextBlock Text="{Binding Value}" 
                                   Grid.Row="1" 
                                   FontSize="25" 
                                   Margin="10,0,0,0" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Left" 
                                   VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width=".25*"/>
            </Grid.ColumnDefinitions>
            
            <lvc:CartesianChart 
                Series="{Binding ScatterSeries}"
                XAxes="{Binding ScatterAxisX}"
                YAxes="{Binding ScatterAxisY}"
                LegendPosition="{Binding ScatterLegend}"
                ZoomMode="Both">
            </lvc:CartesianChart>
        </Grid>


        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width=".3*"/>
                <ColumnDefinition Width=".3*"/>
                <ColumnDefinition Width=".2*"/>
                <ColumnDefinition Width=".2*"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height=".1*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Viewbox>
                    <TextBlock Text="Average Price" FontWeight="DemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Viewbox>
                <lvc:CartesianChart
                    Grid.Row="1"
                    Series="{Binding BarPrice}"
                    XAxes="{Binding BarPriceX}"
                    YAxes="{Binding BarPriceY}"
                    ZoomMode="Both">
                </lvc:CartesianChart>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height=".1*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Viewbox>
                    <TextBlock Text="Average Price Per GB" FontWeight="DemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Viewbox>
                <lvc:CartesianChart
                    Grid.Row="1"
                    Series="{Binding BarPricePerGB}"
                    XAxes="{Binding BarPerGBX}"
                    YAxes="{Binding BarPerGBY}"
                    ZoomMode="Both">
                </lvc:CartesianChart>
            </Grid>


            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height=".1*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Viewbox>
                    <TextBlock Text="DDR4 VS DDR5 Comparison" FontWeight="DemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Viewbox>

                <lvc:CartesianChart
                    Grid.Row="1"
                    Series="{Binding BarOverallComparison}"
                    XAxes="{Binding BarOverallX}"
                    ZoomMode="Both">
                </lvc:CartesianChart>
            </Grid>

            
            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height=".1*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Viewbox>
                    <TextBlock Text="Capacity Distribution" FontWeight="DemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Viewbox>
                
                <lvc:CartesianChart
                    Margin="0,10,0,0"
                    Grid.Row="1"
                    Series="{Binding BarCapacityDistribution}"
                    XAxes="{Binding BarcapacityX}"
                    YAxes="{Binding BarcapacityY}"
                    ZoomMode="Both">
                </lvc:CartesianChart>
            </Grid>
        </Grid>
    </Grid>
</Window>
