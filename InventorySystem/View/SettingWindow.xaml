<Window x:Class="InventorySystem.View.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InventorySystem.View"
        xmlns:UserControls="clr-namespace:InventorySystem.View.UserControls"
        mc:Ignorable="d"
        Title="SettingWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <Grid Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width=".3*"/>
                    <ColumnDefinition Width=".25*"/>
                    <ColumnDefinition Width=".25*"/>
                    <ColumnDefinition Width=".1*"/>
                    <ColumnDefinition Width=".1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Brand Setting"/>
                <ComboBox Margin="5,0,5,0" Grid.Column="1" ItemsSource="{Binding Options, UpdateSourceTrigger=PropertyChanged}" SelectedValue="{Binding BrandOld}"/>
                <Border Grid.Column="2" Margin="5,0,5,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="Gray"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="2"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReady}" Value="False">
                                    <Setter Property="BorderBrush" Value="Red"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <TextBox
                    Text="{Binding BrandNew, UpdateSourceTrigger=PropertyChanged}"/>
                </Border>
                <Button Margin="5,0,5,0" Grid.Column="3" Content="Update" Command="{Binding UpdateBrandCommand}"/>
                <Button Margin="5,0,5,0" Grid.Column="4" Content="Delete" Background="Red" Foreground="White" Command="{Binding DeleteBrandCommand}"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
