<Window x:Class="InventorySystem.View.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InventorySystem.View"
        xmlns:AddWindowUC="clr-namespace:InventorySystem.View.UserControls.AddWindow"
        mc:Ignorable="d"
        Title="AddWindow" Height="450" Width="800">
    <Grid>
        <TabControl Grid.Row="0">
            <TabItem Header="Ram Data" DataContext="{Binding AddRamVM}">
                <AddWindowUC:AddRamUC/>
            </TabItem>
            <TabItem Header="Brand Data" DataContext="{Binding AddBrandVM}">
                <AddWindowUC:AddBrandUC/>
            </TabItem>
            <TabItem Header="To Be Develop" IsEnabled="False"></TabItem>
        </TabControl>
    </Grid>
</Window>
